{
  "expo": {
    "name": "AdGenius AI",
    "slug": "adgenius-mobile",
    "version": "1.0.0",
    "scheme": "adgenius",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adgenius.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "AdGenius uses your camera to photograph products for AI-powered ad generation.",
        "NSPhotoLibraryUsageDescription": "AdGenius reads your photos to select product images for ad generation.",
        "NSPhotoLibraryAddUsageDescription": "AdGenius saves generated ad images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "package": "com.adgenius.mobile",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow AdGenius to access your photos.",
          "savePhotosPermission": "Allow AdGenius to save generated images.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "geminiApiKey": ""
    }
  }
}
